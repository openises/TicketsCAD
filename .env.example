# TicketsCAD NewUI — Docker Compose environment.
# Copy to `.env` (`cp .env.example .env`) and change the passwords before
# `docker compose up -d`. `.env` is gitignored.

# ── Database ────────────────────────────────────────────────────
NEWUI_DB_NAME=newui
NEWUI_DB_USER=newui
NEWUI_DB_PASS=change-me-to-a-strong-db-password
DB_ROOT_PASSWORD=change-me-to-a-strong-root-password

# ── Web ─────────────────────────────────────────────────────────
# Host port the app is published on (http://localhost:<NEWUI_PORT>).
NEWUI_PORT=8081
# Public URL the app builds links with. For a real deployment behind TLS,
# set this to your https:// hostname (must match your certificate).
NEWUI_BASE_URL=http://localhost:8081

# ── First-run admin account ─────────────────────────────────────
# Leave ADMIN_PASSWORD blank to have a random one generated and printed to the
# container log on first start. First login forces you to choose a new one.
ADMIN_USER=admin
ADMIN_EMAIL=admin@example.invalid
ADMIN_PASSWORD=

# ── Demo data ───────────────────────────────────────────────────
# true = seed demo incident types + a few sample units/facilities on first
# install (handy for evaluating). false = empty system ready for real data.
NEWUI_SEED_DEMO=false
