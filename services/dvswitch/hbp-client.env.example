# /etc/ticketscad/hbp-client.env  (mode 0640 — bearer is sensitive)
#
# Phase 85f-10: env for ticketscad-hbp-client.service. Mirrors the
# manual nohup launch command that was in shell history, captured
# here so a host reboot or process crash leaves us with a service
# that auto-restarts instead of a silent outage.
#
# Install:
#   sudo install -m 0640 -o root -g ticketscad \
#       services/dvswitch/hbp-client.env.example /etc/ticketscad/hbp-client.env
#   sudo vim /etc/ticketscad/hbp-client.env    # fill in real values

# Shared secret between bridge and TicketsCAD proxy/widget. Generate
# with `openssl rand -hex 32`. NEVER commit the real value — it lives
# only in /etc/ticketscad/ on the bridge host. The matching value is
# stored in the `dmr_channels.bridge_token` column.
DMR_BEARER_TOKEN=REPLACE_ME_WITH_OPENSSL_RAND_HEX_32

# HTTP control port the proxy POSTs /tx/text + the widget connects to
# /audio-stream on. Apache vhost proxies wss://.../dmr-ws → here.
DMR_HTTP_PORT=18091

# Operator's own DMR ID (radioid.net registration). Used as src_id on
# all locally-originated TX.
DMR_OPERATOR_ID=0

# Default talkgroup for /tx/text when no `talkgroup` field is supplied.
DMR_DEFAULT_TG=0

# Piper TTS binary + voice model.
DMR_PIPER_BIN=/opt/ticketscad-dvswitch/venv/bin/piper
DMR_PIPER_VOICE=/opt/ticketscad-dvswitch/voices/en_US-lessac-medium.onnx

# Python import path — hbp_client.py imports services.dvswitch.* helpers.
PYTHONPATH=/opt/ticketscad-dvswitch
