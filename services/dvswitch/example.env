# Example env file for a DVSwitch bridge instance
# Copy to /etc/ticketscad/dvswitch-<instance>.env and adjust.
# `ticketscad-dvswitch@tg91.service` reads `/etc/ticketscad/dvswitch-tg91.env`.

DMR_INSTANCE=tg91

# USRP ports between bridge.py and Analog_Bridge. Per the spec, pick
# BASE=33000+100×index so multi-talkgroup instances don't collide.
DMR_USRP_LISTEN_PORT=33001
DMR_USRP_SEND_PORT=33000
DMR_USRP_SEND_HOST=127.0.0.1

# HTTP control endpoint. NewUI hits this through the per-channel
# bearer token stored in dmr_channels.bridge_token.
DMR_HTTP_PORT=18091
DMR_BEARER_TOKEN=replace-with-output-of-openssl-rand-hex-32

# Where call records are appended as JSONL (one line per call,
# direction + transcript + duration). Future Phase 73m will also POST
# these to api/dmr-ingest.php for persistence in dmr_messages.
DMR_AUDIT_DIR=/var/log/ticketscad-dvswitch

# DEBUG / INFO / WARNING
DMR_LOG_LEVEL=INFO

# Phase 73l — TicketsCAD ingest endpoint. When set, each finalised
# call is POSTed here with DMR_INGEST_TOKEN as the bearer, so
# dmr_messages stays in sync with the bridge's local JSONL. Use the
# same token that was minted for this channel through the Settings
# panel (it's the one stored hashed on dmr_channels.bridge_token).
DMR_INGEST_URL=https://your-server.example.com/api/dmr-ingest.php
DMR_INGEST_TOKEN=same-as-DMR_BEARER_TOKEN-above

# Phase 73m — Piper TTS for text-to-speech TX. Both DMR_PIPER_BIN and
# DMR_PIPER_VOICE must be set to enable the /tx/text HTTP endpoint;
# leave blank to disable TTS. Default voice is Lessac medium (22050 Hz);
# Piper output is resampled to 8 kHz by ffmpeg inline.
DMR_PIPER_BIN=/opt/ticketscad-dvswitch/venv/bin/piper
DMR_PIPER_VOICE=/opt/ticketscad-dvswitch/voices/en_US-lessac-medium.onnx
DMR_FFMPEG_BIN=ffmpeg

# Phase 73n — Vosk STT for transcribing RX. Path to an unzipped vosk
# model directory; leave blank to disable. The vosk-small English
# model (~40 MB) is the default — fast enough for streaming, accurate
# enough for short tactical traffic. Drop in a larger model later if
# you want higher accuracy at the cost of more RAM + CPU.
DMR_VOSK_MODEL=/opt/ticketscad-dvswitch/models/vosk-model-small-en-us-0.15

# Phase 77b — DVR-style raw audio recording. When set, every finalised
# RX call is written to <DMR_RECORDINGS_DIR>/<instance>/<YYYY>/<MM>/<DD>/
# as a single-channel 8 kHz 16-bit WAV. The dispatcher's DMR panel in
# TicketsCAD exposes an inline HTML5 audio player with scrub + 0.75×–2×
# playback speed for catching up on missed traffic.
#
# Storage budget: a 30-second call is ~480 KB. 100 calls/hour ≈ 50 MB/h.
# At default 7-day retention, plan for ~8 GB per busy talkgroup; less
# for quieter ones. The hourly sweep deletes WAVs older than the
# retention window. Leave DMR_RECORDINGS_DIR blank to disable recording.
DMR_RECORDINGS_DIR=/var/lib/ticketscad-dvswitch/recordings
DMR_RECORDING_RETENTION_HOURS=168

# Phase 77c — preempt active RX when TX is requested? BrandMeister
# does not support this; leave false. Reserved for future hotspot /
# local repeater modes where TX-over-RX is physically possible.
DMR_PREEMPT_ACTIVE_RX=false

# Phase 80a — optional secondary STT via faster-whisper. When set
# alongside DMR_VOSK_MODEL, both transcribers run on every finalised
# call; the whisper output overrides the displayed transcript on
# dmr_messages while Vosk stays in transcript_partials for comparison.
#
# Models — pick by accuracy/latency tradeoff:
#   tiny    ~75 MB   fastest, lowest accuracy
#   base    ~145 MB  good baseline, ~1-2s extra per 10s call (dvswitch-01)
#   small   ~480 MB  noticeably better on accents/numbers
#   medium  ~1.5 GB  diminishing returns vs. the cost
#
# Models download on first use to ~/.cache/huggingface. For air-gapped
# installs, pre-stage with `huggingface-cli download Systran/faster-whisper-<size>`
# and set HF_HOME.
#
# Compute type — int8 default is right for the 4 GB dvswitch-01 spec.
# Use int8_float16 on boxes with more memory; float16 if you have a GPU
# (not relevant on the current VM).
DMR_WHISPER_MODEL=
DMR_WHISPER_COMPUTE=int8
